{
  "manifest_version": 3,
  "name": "AI Group Chat",
  "version": "2.0",
  "description": "Multi-AI group chat across ChatGPT, Gemini, and Claude — brainstorm, debate, or commentary.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Open AI Group Chat"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["chatgpt-main-world.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*"
      ],
      "js": ["ai-connector.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["group-chat.html", "arkose-api.js", "v2/api.js", "branch-store.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
